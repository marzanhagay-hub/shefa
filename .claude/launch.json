{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "serve (static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "http-server (static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "8080", "--cors", "-c-1"],
      "port": 8080
    }
  ]
}
